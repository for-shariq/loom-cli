{
  "version": "0.2.0",

  "configurations": [
    {
      "name": "loom: list",

      "type": "debugpy",

      "request": "launch",

      "module": "loom.cli",

      "args": ["list"],

      "console": "integratedTerminal",

      "env": { "LOOM_DEV_MODE": "1" }
    },

    {
      "name": "loom: install python-coding-standards",

      "type": "debugpy",

      "request": "launch",

      "module": "loom.cli",

      "args": [
        "install",
        "python-coding-standards",
        "--target",
        "copilot",
        "--force"
      ],

      "cwd": "${workspaceFolder}/../sandbox",

      "console": "integratedTerminal",

      "env": { "LOOM_DEV_MODE": "1" }
    },

    {
      "name": "loom: doctor",

      "type": "debugpy",

      "request": "launch",

      "module": "loom.cli",

      "args": ["doctor"],

      "cwd": "${workspaceFolder}/../sandbox",

      "console": "integratedTerminal"
    }
  ]
}
